#!/usr/bin/env bash
set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

PROJECT_NAME="booking_app"

print_info()    { echo -e "${BLUE}[INFO]${NC} $1"; }
print_success() { echo -e "${GREEN}[OK]${NC} $1"; }
print_warning() { echo -e "${YELLOW}[WARN]${NC} $1"; }
print_error()   { echo -e "${RED}[ERROR]${NC} $1"; }

case "$1" in

  # ─── Start/Stop ───────────────────────────────────────────────
  up)
    print_info "Starting containers..."
    docker compose up -d
    print_success "Containers are up. App: http://localhost:8080 | Mail: http://localhost:8025"
    ;;

  down)
    print_info "Stopping containers..."
    docker compose down
    print_success "Containers stopped."
    ;;

  restart)
    docker compose down && docker compose up -d
    ;;

  # ─── Install / Bootstrap ──────────────────────────────────────
  install)
    print_info "Installing a fresh Laravel project..."

    # Install into a temp dir first (avoids the "directory not empty" error),
    # then move everything back to the working directory root.
    docker compose run --rm app bash -c "
      composer create-project laravel/laravel /tmp/laravel_tmp --prefer-dist --no-interaction \
      && shopt -s dotglob \
      && mv /tmp/laravel_tmp/* /var/www/html/ \
      && rm -rf /tmp/laravel_tmp
    "

    print_info "Merging Docker .env with Laravel .env.example..."
    # Keep our DB/Redis/mail values but pull any new keys from .env.example
    docker compose exec app bash -c "
      if [ -f .env.example ] && [ ! -f .env ]; then cp .env.example .env; fi
    "

    print_info "Generating application key..."
    docker compose exec app php artisan key:generate

    print_info "Running migrations..."
    docker compose exec app php artisan migrate --force

    print_success "Laravel installed and ready!"
    print_success "App: http://localhost:8080"
    ;;

  # ─── Artisan shortcut ─────────────────────────────────────────
  artisan)
    shift
    docker compose exec app php artisan "$@"
    ;;

  # ─── Composer shortcut ────────────────────────────────────────
  composer)
    shift
    docker compose exec app composer "$@"
    ;;

  # ─── Shell into containers ────────────────────────────────────
  shell)
    docker compose exec app bash
    ;;

  shell-mysql)
    docker compose exec mysql bash -c 'mysql -u${MYSQL_USER} -p${MYSQL_PASSWORD} ${MYSQL_DATABASE}'
    ;;

  # ─── Logs ─────────────────────────────────────────────────────
  logs)
    shift
    docker compose logs -f "${@:-app}"
    ;;

  # ─── Build ────────────────────────────────────────────────────
  build)
    print_info "Building images..."
    docker compose build --no-cache
    print_success "Build complete."
    ;;

  # ─── Cleanup ──────────────────────────────────────────────────
  clean)
    print_warning "This will remove containers AND volumes (DB data will be lost)."
    read -r -p "Continue? [y/N] " confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || exit 0
    docker compose down -v --remove-orphans
    print_success "Cleaned up."
    ;;

  # ─── Help ─────────────────────────────────────────────────────
  *)
    echo ""
    echo -e "${BLUE}Usage:${NC} ./dev [command]"
    echo ""
    echo "  up          Start all containers"
    echo "  down        Stop all containers"
    echo "  restart     Restart all containers"
    echo "  install     Install a fresh Laravel project & run migrations"
    echo "  artisan     Run an Artisan command  (e.g. ./dev artisan migrate)"
    echo "  composer    Run a Composer command  (e.g. ./dev composer require spatie/...)"
    echo "  shell       Open a bash shell in the app container"
    echo "  shell-mysql Open a MySQL shell"
    echo "  logs        Tail logs  (default: app; pass service name to override)"
    echo "  build       Rebuild Docker images"
    echo "  clean       Remove containers AND volumes (destructive)"
    echo ""
    ;;
esac
